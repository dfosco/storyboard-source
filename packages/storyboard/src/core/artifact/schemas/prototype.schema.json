{
  "$id": "artifact:prototype",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 64,
      "description": "Kebab-case identifier (unique within scope)"
    },
    "title": {
      "type": "string",
      "description": "Human-readable display title"
    },
    "description": {
      "type": "string",
      "description": "Short description"
    },
    "author": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ],
      "description": "Author name(s)"
    },
    "folder": {
      "type": "string",
      "description": "Parent .folder directory"
    },
    "icon": {
      "type": "string",
      "description": "Emoji or icon identifier"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Categorization tags"
    },
    "team": {
      "type": "string",
      "description": "Team name"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "External URL — when present, prototype is external (no index.jsx generated)"
    },
    "flow": {
      "type": "boolean",
      "default": false,
      "description": "Create a default flow file alongside"
    },
    "partial": {
      "type": "string",
      "description": "Template/recipe name"
    }
  },
  "mutuallyExclusive": [["url", "flow"]]
}
