{
  "name": "@dfosco/storyboard-core",
  "version": "4.2.6",
  "type": "module",
  "license": "MIT",
  "bin": {
    "storyboard-scaffold": "./src/scaffold.js",
    "storyboard": "./src/cli/index.js",
    "sb": "./src/cli/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dfosco/storyboard.git",
    "directory": "packages/core"
  },
  "files": [
    "src",
    "dist",
    "scaffold",
    "toolbar.config.json",
    "widgets.config.json",
    "paste.config.json",
    "commandpalette.config.json"
  ],
  "scripts": {
    "build:css": "tailwindcss -i src/styles/tailwind.css -o dist/tailwind.css --minify",
    "build:ui": "vite build --config vite.ui.config.js",
    "dev:ui": "vite build --config vite.ui.config.js --watch",
    "prepublishOnly": "npm run build:css && npm run build:ui",
    "check:imports": "echo 'no svelte checks needed'"
  },
  "exports": {
    ".": "./src/index.js",
    "./toolbar.config.json": "./toolbar.config.json",
    "./widgets.config.json": "./widgets.config.json",
    "./paste.config.json": "./paste.config.json",
    "./commandpalette.config.json": "./commandpalette.config.json",
    "./ui-runtime": "./dist/storyboard-ui.js",
    "./ui-runtime/style.css": "./dist/storyboard-ui.css",
    "./canvas/materializer": "./src/canvas/materializer.js",
    "./vite/server": "./src/vite/server-plugin.js",
    "./comments": "./src/comments/index.js",
    "./comments/ui/comments.css": "./src/comments/ui/comment-layout.css",
    "./comments/ui/comment-layout.css": "./src/comments/ui/comment-layout.css",
    "./workshop/ui/mount.js": "./src/workshop/ui/mount.ts",
    "./modes.css": "./src/modes.css",
    "./ui/design-modes": "./src/ui/design-modes.ts",
    "./ui/viewfinder": "./src/ui/viewfinder.ts",
    "./styles/tailwind.css": "./dist/tailwind.css",
    "./worktree/port": "./src/worktree/port.js",
    "./worktree/serverRegistry": "./src/worktree/serverRegistry.js",
    "./canvas/collision": "./src/canvas/collision.js",
    "./canvas/identity": "./src/canvas/identity.js",
    "./canvas/writeGuard": "./src/canvas/writeGuard.js",
    "./config": "./src/configSchema.js",
    "./inspector/highlighter": "./src/inspector/highlighter.js",
    "./smooth-corners": "./src/smoothCorners.js"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@primer/octicons": "^19.22.0",
    "feather-icons": "^4.29.2",
    "highlight.js": "^11.11.1",
    "html-to-image": "^1.11.13",
    "iconoir": "^7.11.0",
    "jsonc-parser": "^3.3.1",
    "lucide-react": "^1.8.0",
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "clsx": "^2.1.1",
    "marked": "^17.0.5",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.0.0"
  },
  "optionalDependencies": {
    "node-pty": "^1.0.0"
  }
}
