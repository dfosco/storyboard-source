{
    "name": "storyboard",
    "private": true,
    "type": "module",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "dev": "storyboard dev",
        "dev:vite": "vite",
        "build": "vite build",
        "lint": "eslint . && npm run check:imports -w @dfosco/storyboard-core",
        "preview": "vite preview",
        "prepare": "git config core.hooksPath .githooks",
        "changeset": "changeset",
        "version": "changeset version && node scripts/sync-root-version.js",
        "tag": "changeset tag",
        "test": "vitest run",
        "test:integration": "vitest run --config vitest.integration.config.js",
        "test:watch": "vitest",
        "test:core": "vitest run packages/core",
        "test:react": "vitest run packages/react",
        "sync": "./scripts/sync-local.sh",
        "sync:no-build": "./scripts/sync-local.sh --no-build",
        "release": "./scripts/release.sh",
        "release:beta": "PRERELEASE_TAG=beta ./scripts/release.sh",
        "release:alpha": "PRERELEASE_TAG=alpha ./scripts/release.sh",
        "release:resume": "./scripts/release-resume.sh",
        "release:resume:beta": "PRERELEASE_TAG=beta ./scripts/release-resume.sh",
        "release:resume:alpha": "PRERELEASE_TAG=alpha ./scripts/release-resume.sh",
        "test:svelte": "vitest run --config packages/svelte-ui/vitest.config.ts",
        "build:ui": "npm run build:ui -w @dfosco/storyboard-core",
        "dev:ui": "npm run dev:ui -w @dfosco/storyboard-core",
        "link": "npm run build:ui && ./scripts/link.sh && npm run dev",
        "unlink": "./scripts/unlink.sh",
        "setup": "./scripts/setup.sh",
        "hotel:add": "storyboard proxy",
        "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-*/spawn-helper 2>/dev/null || true"
    },
    "dependencies": {
        "@base-ui/react": "^1.4.0",
        "@generouted/react-router": "^1.19.11",
        "@internationalized/date": "^3.12.0",
        "@lucide/svelte": "^1.7.0",
        "@primer/octicons-react": "^19.21.1",
        "@primer/primitives": "^11.3.2",
        "@primer/react": "^38.5.0",
        "@radix-ui/react-avatar": "^1.1.11",
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-collapsible": "^1.1.12",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-separator": "^1.1.8",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-toggle": "^1.1.10",
        "@radix-ui/react-toggle-group": "^1.1.11",
        "@radix-ui/react-tooltip": "^1.2.8",
        "cmdk": "^1.1.1",
        "ghostty-web": "^0.4.0",
        "jsonc-parser": "^3.3.1",
        "node-pty": "^1.1.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-is": "^19.2.0",
        "react-router-dom": "^7.12.0",
        "web-vitals": "^5.1.0",
        "ws": "^8.20.0"
    },
    "devDependencies": {
        "@changesets/changelog-github": "^0.6.0",
        "@changesets/cli": "^2.29.8",
        "@csstools/postcss-global-data": "3.0.0",
        "@eslint/js": "^9.35.0",
        "@github/browserslist-config": "^1.0.0",
        "@tailwindcss/vite": "^4.2.2",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^19.2.5",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.2",
        "@vitest/ui": "^4.0.18",
        "eslint": "^9.39.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.26",
        "glob": "^13.0.5",
        "globals": "^17.0.0",
        "highlight.js": "^11.11.1",
        "jsdom": "^28.1.0",
        "marked": "^17.0.5",
        "postcss-preset-env": "^10.6.0",
        "tailwindcss": "^4.2.2",
        "vite": "^7.3.1",
        "vitest": "^4.0.18"
    },
    "version": "4.2.8"
}
