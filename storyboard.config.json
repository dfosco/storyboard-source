{
  "devDomainColor": "#c77f25",
  "port": 1236,
  "prodDomain": "https://dfosco.github.io/storyboard/",
  "repository": {
    "owner": "dfosco",
    "name": "storyboard"
  },
  "modes": {
    "enabled": false
  },
  "comments": {
    "discussions": {
      "category": "General"
    }
  },
  "featureFlags": {
    "show-banner": true
  },
  "workshop": {
    "features": {
      "createPrototype": true,
      "createFlow": true,
      "createCanvas": true
    },
    "partials": [
      {
        "directory": "template",
        "name": "Application"
      }
    ]
  },
  "canvas": {
    "zoom": {
      "min": 10,
      "max": 250,
      "step": 5
    }
  },
  "hotPool": {
    "enabled": true,
    "verbose": false,
    "default_pool_size": 1,
    "default_max_pool_size": 3,
    "load_balancer": false,
    "load_balancer_cooldown_mins": 10,
    "pools": {
      "terminal": {
        "pool_size": 1
      },
      "copilot": {
        "pool_size": 2,
        "webgl_ready_slots": 2
      },
      "claude": {
        "pool_size": 2,
        "webgl_ready_slots": 2
      },
      "codex": {
        "pool_size": 0
      },
      "prompt": {
        "pool_size": 2,
        "webgl_ready_slots": 2  
      }
    }
  },
  "customerMode": {
    "enabled": false,
    "hideChrome": false,
    "hideHomepage": false,
    "protoHomepage": ""
  }
}
